# SonarQube
SONARQUBE_URL=https://sonarqube-001.hanpda.com
SONARCUBE_TOKEN=your_sonarqube_token

# Jira
JIRA_URL=https://jira.example.com
JIRA_ID=your_jira_id
JIRA_PASSWORD=your_jira_password
PROJECT_KEY=ODIN
JIRA_ENABLED=true  # false로 설정하면 Jira 대신 리포트 문서만 생성

# Google Sheets
SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_CREDENTIALS=credentials.json

# Workflow
ASSIGNEE_NAME=홍길동
MAX_CONCURRENT_AGENTS=5  # 동시 실행 서브에이전트 수 (2-10, 기본값 5)

# Repository
REPO_PATH=repo/odin_addsvc_extsvc-backend
REPO_URL=git@github.com:your-org/odin_addsvc_extsvc-backend.git
REPO_BRANCH=main

# 프로젝트별 코딩 규칙 (선택사항 - 미설정 시 일반 코딩 관행 적용)
CODING_RULES_PATH=

# Test (선택사항 - 미설정 시 자동 감지)
TEST_COMMAND=                # 커스텀 테스트 명령어 (예: ./gradlew test, pytest)
VENV_PATH=                   # Python venv 경로, REPO_PATH 기준 상대경로 (예: venv, .venv)

# Debug
DEBUG_MODE=false  # true면 작업 기록을 history/{issue_key}/ 폴더에 저장
